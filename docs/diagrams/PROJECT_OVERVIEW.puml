@startuml 8090PCB_User_Flow_Sequence
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam shadowing false

title 8090PCB User Flow Sequence Diagram

participant "User" as user
participant "React Frontend" as frontend
participant "Express Server" as server
participant "File Service" as file_service
participant "PCB Validator" as validator
participant "LLM Agent Service" as llm_service
participant "LlamaIndex Agent" as ai_agent
participant "MCP Bridge" as mcp_bridge
participant "FastMCP Server" as mcp_server
participant "KiCad CLI" as kicad_cli
participant "Ollama LLM" as ollama
database "File System" as filesystem
database "STM32 Docs" as stm32_docs

autonumber 1

== File Upload Phase ==

user -> frontend: Drag & Drop KiCad files
frontend -> frontend: Validate file types
frontend -> frontend: Create validation ID
frontend -> server: POST /api/pcb/validate

activate server

server -> file_service: handleFileUpload()
activate file_service

file_service -> filesystem: Create upload directory
file_service -> filesystem: Store uploaded files
file_service --> server: Return file paths

deactivate file_service

server -> validator: validateFiles(validationId, filePaths)
activate validator

== File Parsing Phase ==

validator -> validator: Parse KiCad files
validator -> validator: Extract component list
validator -> validator: Identify microcontrollers

== MCP Analysis Phase ==

validator -> mcp_bridge: connectToServer()
activate mcp_bridge

mcp_bridge -> mcp_server: MCP handshake
activate mcp_server

mcp_bridge --> validator: Return MCP client

deactivate mcp_server

validator -> mcp_bridge: callTool("analyze_pcb", {components})
activate mcp_bridge

mcp_bridge -> mcp_server: Execute analysis tool
activate mcp_server

mcp_server -> mcp_server: Extract component information
mcp_server -> mcp_server: Analyze circuit topology
mcp_server --> mcp_bridge: Return analysis results

deactivate mcp_server

mcp_bridge --> validator: Return component analysis

deactivate mcp_bridge

== Design Rule Check Phase ==

validator -> mcp_bridge: callTool("run_drc", {pcb_file})
activate mcp_bridge

mcp_bridge -> mcp_server: Execute DRC tool
activate mcp_server

mcp_server -> kicad_cli: kicad-cli drc [pcb_file]
activate kicad_cli

kicad_cli --> mcp_server: DRC report

deactivate kicad_cli

mcp_server --> mcp_bridge: Return DRC results

deactivate mcp_server

mcp_bridge --> validator: Return DRC report

deactivate mcp_bridge

== AI Analysis Phase ==

validator -> llm_service: spawnAgent('firmware_mode')
activate llm_service

llm_service -> ai_agent: Start Python subprocess
activate ai_agent

ai_agent -> ai_agent: Initialize LlamaIndex
ai_agent --> llm_service: Agent ready

deactivate ai_agent

llm_service --> validator: Return agent handle

deactivate llm_service

validator -> llm_service: processRequest(analysis_data)
activate llm_service

llm_service -> ai_agent: Send analysis request
activate ai_agent

ai_agent -> stm32_docs: Query relevant documentation
activate stm32_docs

stm32_docs --> ai_agent: Return technical documents

deactivate stm32_docs

ai_agent -> ollama: Generate embeddings
activate ollama

ollama --> ai_agent: Return vector embeddings

deactivate ollama

ai_agent -> ai_agent: Perform RAG retrieval
ai_agent -> ollama: Rerank documents
activate ollama

ollama --> ai_agent: Return ranked results

deactivate ollama

ai_agent -> ollama: Generate firmware plan
activate ollama

ollama --> ai_agent: Return structured response

deactivate ollama

ai_agent --> llm_service: Return AI analysis results

deactivate ai_agent

llm_service --> validator: Return firmware plan and PRD

deactivate llm_service

== PCB Rendering Phase ==

validator -> kicad_cli: kicad-cli export --format svg
activate kicad_cli

kicad_cli -> filesystem: Read PCB file
kicad_cli -> filesystem: Write SVG render
kicad_cli --> validator: Return SVG file path

deactivate kicad_cli

== Results Generation Phase ==

validator -> filesystem: Save firmware plan (Markdown)
validator -> filesystem: Save PRD summary (Markdown)
validator -> filesystem: Save validation summary (JSON)
validator -> filesystem: Save PCB render (SVG)

validator --> server: Return validation results

deactivate validator

== Response Phase ==

server -> server: Format response JSON
server --> frontend: POST response (200 OK)

deactivate server

== Frontend Display Phase ==

frontend -> frontend: Parse response data
frontend -> frontend: Update UI with results
frontend -> user: Show validation results

@enduml

@startuml 8090PCB_Data_Flow_Activity
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam shadowing false

title 8090PCB Data Processing Activity Diagram

start

:User uploads KiCad files;
if (File validation successful?) then (yes)
  :Parse KiCad project file;
  :Extract schematic data;
  :Parse PCB layout;
  :Extract component list;
  
  fork
    :MCP Analysis;
    :Extract component information;
    :Analyze circuit topology;
    :Generate BOM;
  fork again
    :Design Rule Check;
    :Run KiCad CLI DRC;
    :Generate DRC report;
  fork again
    :PCB Rendering;
    :Generate SVG visualization;
  end fork
  
  :AI Analysis;
  :Query STM32 documentation;
  :Generate embeddings;
  :Perform RAG retrieval;
  :Generate firmware plan;
  :Create PRD summary;
  
  :Generate results;
  :Save firmware plan (MD);
  :Save PRD summary (MD);
  :Save validation summary (JSON);
  :Save PCB render (SVG);
  
  :Return results to user;
  
  stop
else (no)
  :Display validation error;
  :Suggest file corrections;
  stop
endif

@enduml

@startuml 8090PCB_Component_Relationships
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam shadowing false

title 8090PCB Component Class Relationships

class ReactApp {
  +main()
  +setupRouter()
  +render()
}

class PcbValidator {
  +handleFileUpload()
  +validateFiles()
  +displayResults()
  -uploadState
  -validationResults
}

class ExpressServer {
  +start()
  +setupMiddleware()
  +setupRoutes()
  -app
  -port
}

class PcbValidatorService {
  +validateFiles()
  +processUpload()
  +generateResults()
  -validationId
  -uploadPath
}

class LlmAgentService {
  +spawnAgent()
  +processRequest()
  +handleResponse()
  -agentProcess
  -modelConfig
}

class FastMcpServer {
  +setup()
  +registerResources()
  +registerTools()
  -lifespanManager
}

class LlamaIndexAgent {
  +initialize()
  +processQuery()
  +generateResponse()
  -queryEngine
  -retriever
}

interface IMcpTool {
  +execute(params: Map)
  +validate(params: Map)
  +getDescription()
}

interface IValidationService {
  +validate(request: ValidationRequest)
  +getStatus(validationId: string)
}

class AnalysisTools {
  +analyzePcb()
  +extractComponents()
  +validateDesign()
}

class DrcTools {
  +runDesignRuleCheck()
  +generateReport()
  +checkViolations()
}

' Relationships
ReactApp --> PcbValidator : renders
PcbValidator --> ExpressServer : API calls
ExpressServer --> PcbValidatorService : routes
PcbValidatorService --> LlmAgentService : calls
LlmAgentService --> FastMcpServer : MCP protocol
FastMcpServer --> LlamaIndexAgent : AI processing

' Interface implementations
AnalysisTools ..|> IMcpTool
DrcTools ..|> IMcpTool
PcbValidatorService ..|> IValidationService

' Inheritance
class ComponentValidator {
  +validateFile()
  +checkIntegrity()
}
class FileProcessor {
  +processFile()
  +extractData()
}
AnalysisTools --|> ComponentValidator
DrcTools --|> ComponentValidator

@enduml

@startuml 8090PCB_Deployment_Architecture
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam shadowing false

title 8090PCB Deployment Architecture

deployment "Production Environment" {
  
  node "Web Server" as web_server {
    component "Nginx" as nginx
    component "React Frontend" as react_frontend
  }
  
  node "Application Server" as app_server {
    component "Node.js Runtime" as nodejs
    component "Express Backend" as express_backend
  }
  
  node "MCP Server" as mcp_host {
    component "Python Runtime" as python
    component "FastMCP Server" as fastmcp_deploy
  }
  
  node "AI Services" as ai_host {
    component "Ollama LLM" as ollama_deploy
    component "LlamaIndex Agent" as llamaindex_deploy
  }
  
  node "EDA Services" as eda_host {
    component "KiCad CLI" as kicad_deploy
  }
  
  node "Storage" as storage_host {
    artifact "File System" as fs_storage
    artifact "Upload Directory" as upload_storage
    artifact "Generated Files" as generated_storage
  }
  
  node "Database" as db_host {
    database "STM32 Documentation" as stm32_db
    database "Vector Database" as vector_db
  }
}

' Network connections
web_server --> app_server : HTTPS
app_server --> mcp_host : MCP Protocol
app_server --> ai_host : HTTP/gRPC
app_server --> eda_host : CLI calls
app_server --> storage_host : File I/O
ai_host --> db_host : Document queries

' User access
actor "End User" as end_user
end_user --> web_server : Browser

' Load balancer (if applicable)
node "Load Balancer" as lb
lb --> web_server

' Monitoring
node "Monitoring" as monitoring
monitoring --> app_server : Metrics
monitoring --> mcp_host : Health checks
monitoring --> ai_host : Performance

@enduml

