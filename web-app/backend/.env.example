PORT=3001
NODE_ENV=development

# ======== LLM Provider ========
# "groq" (free cloud, default) or "ollama" (local)
LLM_PROVIDER=groq

# --- Groq (cloud) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Embeddings run locally via fastembed (CPU, ~50 MB model)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Ollama (local, uncomment to use) ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_LLM_MODEL=gpt-oss:20b
# OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b

# ======== MCP Server Configuration ========
KICAD_MCP_SERVER_PATH=../../main.py
KICAD_MCP_PYTHON=.venv/bin/python
KICAD_MCP_TIMEOUT_MS=30000
MCP_ENABLED=true
KICAD_SEARCH_PATHS=~/Documents/PCB,~/Electronics,~/Projects/KiCad

# ======== RAG Configuration ========
FIRMWARE_DOCS_DIR=../../stm32
FIRMWARE_INDEX_DIR=./agent/index_stm32
RAG_CHUNK_SIZE=1400
RAG_CHUNK_OVERLAP=180

# ======== KiCad CLI ========
# KICAD_CLI_PATH=/Applications/KiCad/KiCad.app/Contents/MacOS/kicad-cli
KICAD_RENDER_LAYERS=F.Cu,B.Cu,F.SilkS,B.SilkS,F.Mask,B.Mask,Edge.Cuts

# ======== Payload Limits ========
LLM_MAX_FILE_CHARS=120000
LLM_MAX_TOTAL_CHARS=400000

# ======== Agent Overrides ========
# LLAMA_AGENT_PYTHON=/path/to/python
# LLAMA_AGENT_SCRIPT=/absolute/path/to/llamaindex_agent.py
# LLAMA_AGENT_TIMEOUT_MS=45000

# ======== Security ========
# CORS — comma-separated allowed origins (leave blank for permissive in dev)
# CORS_ORIGINS=https://yourdomain.com
